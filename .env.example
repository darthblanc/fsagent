# Copy to .env and fill in the keys you need.
# .env is loaded automatically on startup (cli/repl.py:load_env).

# Provider API keys (only the one matching your chosen model is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LangSmith tracing (optional) — https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fsagent
